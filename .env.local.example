# ── Deploy on Vercel ────────────────────────────────────────────────
# Copy these into Vercel → Project → Settings → Environment Variables
# (Production + Preview). .env.local is NOT uploaded automatically.

# ── Payment provider switch ─────────────────────────────────────────
# Default is Razorpay. Set to "phonepe" to use PhonePe instead.
PAYMENT_PROVIDER=razorpay
# PAYMENT_PROVIDER=phonepe

# ── Razorpay (DEFAULT) ──────────────────────────────────────────────
# Dashboard → https://dashboard.razorpay.com → Account & Settings → API Keys
#
# Required for LIVE payments:
  RAZORPAY_KEY_ID      — Key Id   (rzp_test_… for Test Mode, rzp_live_… for Live)
#   RAZORPAY_KEY_SECRET  — Key Secret (server-only; never expose to the browser)
#
# Optional:
#   RAZORPAY_WEBHOOK_SECRET — Webhook signing secret (if you add webhooks later)
#
# Test Mode: use Test API Keys from the dashboard (toggle "Test Mode" ON).
# Live Mode: switch dashboard to Live, generate Live keys, use those here.
#
# Behaviour:
#   • KEY_ID + KEY_SECRET set  → real Razorpay Checkout
#   • neither set              → TEST MODE (simulated payment screen)
# "Order on WhatsApp" always works regardless of payment config.

# RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
# RAZORPAY_KEY_SECRET=your_key_secret
# RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── PhonePe (ALTERNATIVE — set PAYMENT_PROVIDER=phonepe) ────────────
# By DEFAULT (when PhonePe is selected but no creds) the site runs in
# built-in TEST MODE: a simulated pay screen. Add real credentials below
# to switch to LIVE PhonePe automatically.
#
# NOTE: PhonePe has retired its old PUBLIC sandbox merchants
# (PGTESTPAYUAT / PGTESTPAYUAT86 no longer work). To test against the REAL
# PhonePe UAT, generate your own UAT credentials in the PhonePe Business
# dashboard (Developer Settings) or via PhonePe support.

PHONEPE_ENV=sandbox            # or: production

# --- Standard Checkout v2 (current default; recommended) ---
# PHONEPE_CLIENT_ID=your_client_id
# PHONEPE_CLIENT_SECRET=your_client_secret
# PHONEPE_CLIENT_VERSION=1

# --- OR legacy PG v1 (salt-key merchants) ---
# PHONEPE_MERCHANT_ID=your_merchant_id
# PHONEPE_SALT_KEY=your_salt_key
# PHONEPE_SALT_INDEX=1

# Behaviour (when PAYMENT_PROVIDER=phonepe):
#   • CLIENT_ID + CLIENT_SECRET set  → real PhonePe Standard Checkout (v2, OAuth)
#   • MERCHANT_ID + SALT_KEY set     → real PhonePe legacy PG (v1, X-VERIFY)
#   • neither set                    → TEST MODE (simulated payment)

# ── Order email notifications (Resend) ──────────────────────────────
# Get order details emailed automatically on every PAID order.
# Sign up free at https://resend.com → API Keys.
# Multiple inboxes: comma-separate emails.
# RESEND_API_KEY=re_xxxxxxxx
# ORDER_NOTIFY_EMAIL=you@gmail.com,orders@yourshop.com
# ORDER_FROM_EMAIL=TheTidbit Orders <onboarding@resend.dev>
# ORDER_GSTIN=22AAAAA0000A1Z5          # optional — printed on tax invoices
# (WhatsApp orders always reach you on WhatsApp regardless of email config.)
# After payment: tax invoice (with 5% GST breakup) is emailed to ORDER_NOTIFY_EMAIL
# and to the customer if they entered an email at checkout.
