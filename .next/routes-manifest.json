{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/products/[productId]",
      "regex": "^/products/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPproductId": "nxtPproductId"
      },
      "namedRegex": "^/products/(?<nxtPproductId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/stories/[slug]",
      "regex": "^/stories/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/stories/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/bulk",
      "regex": "^/bulk(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/bulk(?:/)?$"
    },
    {
      "page": "/checkout",
      "regex": "^/checkout(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/checkout(?:/)?$"
    },
    {
      "page": "/collections",
      "regex": "^/collections(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/collections(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/home-one",
      "regex": "^/home\\-one(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/home\\-one(?:/)?$"
    },
    {
      "page": "/ops/tracking",
      "regex": "^/ops/tracking(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/ops/tracking(?:/)?$"
    },
    {
      "page": "/order/pay",
      "regex": "^/order/pay(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/order/pay(?:/)?$"
    },
    {
      "page": "/order/status",
      "regex": "^/order/status(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/order/status(?:/)?$"
    },
    {
      "page": "/products",
      "regex": "^/products(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products(?:/)?$"
    },
    {
      "page": "/stories",
      "regex": "^/stories(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/stories(?:/)?$"
    },
    {
      "page": "/story",
      "regex": "^/story(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/story(?:/)?$"
    },
    {
      "page": "/track",
      "regex": "^/track(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/track(?:/)?$"
    },
    {
      "page": "/wishlist",
      "regex": "^/wishlist(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/wishlist(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}